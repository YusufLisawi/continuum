{
  "description": "Selfmind: inject SOUL/MEMORY/flashbacks at session start, plus a context-usage line after each assistant turn.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|clear|compact",
        "hooks": [
          {
            "type": "command",
            "shell": "bash",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/selfmind-hook.cjs\" session-start",
            "timeout": 15
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "shell": "bash",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/selfmind-hook.cjs\" stop",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
